{
  "triggers": [
    {
      "id": "boiler_lastcode_changed",
      "title": {
        "en": "Heatpum last code changed",
        "nl": "Warmtepomp laatste error veranderd"
      },
      "tokens": [
        {
          "type": "string",
          "name": "boiler_lastcode",
          "title": {
            "en": "Last code",
            "nl": "Laatste error"
          },
          "example": {
            "en": "A01 (5448)"
          }
        }
      ]
    },
    {
      "id": "boiler_dhw_curtemp_less_than",
      "title": {
        "en": "Tap water temp less than",
        "nl": "Drinkwater temperatuur minder dan"
      },
      "titleFormatted": {
        "en": "Tap water temp less than [[boiler_dhw_curtemp]]°C",
        "nl": "Drinkwater temperatuur minder dan [[boiler_dhw_curtemp]]°C"
      },
      "args": [
        {
          "type": "range",
          "name": "boiler_dhw_curtemp",
          "min": 0,
          "max": 100,
          "step": 1
        }
      ],
      "tokens": [
        {
          "type": "number",
          "name": "boiler_dhw_curtemp",
          "title": {
            "en": "Temperature"
          },
          "example": {
            "en": "50"
          }
        }
      ]
    }
  ],
